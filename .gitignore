# Portal SPA build output dropped here by the Dockerfile before
# `cargo build` so rust-embed can bundle it into the velocity-api
# binary. Tracked dir, ignored contents (except README.md as the
# placeholder so the dir survives a clone).
crates/velocity-platform-api/static/*
!crates/velocity-platform-api/static/README.md
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Helm / charts ---
charts/**/charts/
charts/**/Chart.lock
*.tgz

# --- Kubernetes / kubeconfig ---
kubeconfig
*.kubeconfig
.kube/

# --- Secrets ---
*.pem
*.key
!**/testdata/**/*.pem
!**/testdata/**/*.key
secrets/
*.secret.yaml

# --- Local test infra ---
.testcontainers/
docker-compose.override.yml

# Local data volumes mounted by docker-compose (postgres on 5434, redis, kafka, typesense)
data/
pgdata/
redis-data/
kafka-data/

# --- Build / dist artifacts ---
dist/
build/
out/

